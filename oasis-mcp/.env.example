# OASIS MCP Server 환경변수
# 이 파일을 .env 로 복사 후 실제 값으로 채우세요

# ── AI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Slack ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Twilio SMS ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── 카카오 알림톡 ────────────────────────────────────────
KAKAO_API_KEY=...
KAKAO_SENDER_KEY=...

# ── 공공데이터포털 ───────────────────────────────────────
PUBLIC_DATA_KEY=...     # data.go.kr 발급
WEATHER_API_KEY=...     # 기상청 API (data.go.kr 동일 키로도 가능)

# ── 내부 DB ──────────────────────────────────────────────
DB_PATH=oasis_incidents.db
