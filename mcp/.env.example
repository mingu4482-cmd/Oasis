# OASIS MCP Server 환경변수
# 이 파일을 .env 로 복사 후 실제 값으로 채우세요

# ── AI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Slack ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── 솔라피 (Solapi) SMS ──────────────────────────────────
SOLAPI_API_KEY=...
SOLAPI_API_SECRET=...
SOLAPI_FROM_NUMBER=01012345678   # 솔라피에 등록된 발신번호, 하이픈 없이

# ── 카카오 알림톡 ────────────────────────────────────────
KAKAO_API_KEY=...
KAKAO_SENDER_KEY=...

# ── 공공데이터포털 ───────────────────────────────────────
PUBLIC_DATA_KEY=...     # data.go.kr 발급
WEATHER_API_KEY=...     # 기상청 API (data.go.kr 동일 키로도 가능)

# ── 내부 DB ──────────────────────────────────────────────
DB_PATH=oasis_incidents.db

# MCP 서버 (ai-server의 8000번과 분리)
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_TRANSPORT=streamable-http
