{
  "name": "oasis-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:fe": "vite --host 0.0.0.0",
    "dev:be": "node server/index.js",
    "dev:ai": "cd ai-server && .\\.venv\\Scripts\\python.exe -m uvicorn main:app --port 8000",
    "dev:scheduler": "cd ai-server && set PYTHONIOENCODING=utf-8&& .\\.venv\\Scripts\\python.exe scheduler.py",
    "dev:all": "concurrently --names \"dev:fe,dev:be,dev:ai,dev:scheduler\" \"npm.cmd run dev:fe\" \"npm.cmd run dev:be\" \"npm.cmd run dev:ai\" \"npm.cmd run dev:scheduler\"",
    "build": "tsc --noEmit && vite build --config vite.config.ts",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.81.2",
    "axios": "^1.10.0",
    "cesium": "^1.131.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^11.9.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-kakao-maps-sdk": "^1.2.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.1",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^10.0.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-cesium": "^1.2.23"
  }
}
